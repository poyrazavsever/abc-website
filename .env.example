# Supabase project URL.
# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key used by client auth/session flows.
# Even though this key is public, enforce strict RLS policies in Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public app URL for canonical links and metadata.
# Example: http://localhost:3000 (local), https://abc-site.com (production)
# NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Server-only Variables (secrets)
# -----------------------------------------------------------------------------

# Supabase service role key for privileged operations.
# Use only in server contexts (API routes, server actions, cron jobs).
# Never import this in client components.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Luma Integration
# -----------------------------------------------------------------------------

# Luma API key used for event and attendance synchronization.
LUMA_API_KEY=

# Luma calendar used as the source of truth for public event listing.
LUMA_CALENDAR_ID=cal-7VDaKLe8HABNOFw

# Shared secret for verifying Luma webhook signatures.
LUMA_WEBHOOK_SECRET=

# Optional Luma API base URL override.
# Keep commented unless you need a custom proxy.
# LUMA_API_BASE_URL=https://public-api.luma.com

# -----------------------------------------------------------------------------
# Email Integration
# -----------------------------------------------------------------------------

# API key for transactional email provider (Resend, SendGrid, etc).
EMAIL_PROVIDER_API_KEY=

# Optional sender settings used by notification templates.
# EMAIL_FROM=no-reply@example.com
# EMAIL_FROM_NAME=Ankara Build Club

# -----------------------------------------------------------------------------
# Analytics Integration
# -----------------------------------------------------------------------------

# Write key/token for analytics provider (Mixpanel, Hotdog, etc).
ANALYTICS_WRITE_KEY=

# Optional analytics endpoint override.
# ANALYTICS_API_BASE_URL=

# -----------------------------------------------------------------------------
# LLM / RAG Integration
# -----------------------------------------------------------------------------

# API key for LLM provider used by chatbot/RAG services.
LLM_API_KEY=

# Optional model override used by integration layer.
# LLM_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Node runtime mode.
# development | test | production
# NODE_ENV=development
